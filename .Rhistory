install.packages("caugi")
library(caugi)
?caugi
bspm::disable()
install.packages("caugi")
library(caugi)
target <- caugi(Z %-->% A %-->% Y, U %-->% A + Y)
targets <- add_nodes(target, name = "S")
example <- caugi(Z %-->% A %-->% Y, U %-->% A + Y,
Z %-->% S, A %-->% S, class = "ADMG")
edges_add <- c("none", "---", "-->", "<->", "<--")
sets <- as.data.frame(t(sapply(edges_add, \(x) {
with(expand.grid("S", c("Z", "A", "Y", "U")),
paste(Var1, Var2, x, sep = "_"))
})))
allgraphstotest <- do.call(expand.grid, sets)
strtoaddedges <- function(st) {
edgelist <- strsplit(as.character(st), "_", fixed = TRUE)[[1]]
if(edgelist[3] == "none") {
return(data.frame(from = character(0), to = character(0), edge = character(0)))
}
if(edgelist[3] == "<--") {
data.frame(from = edgelist[2], to = edgelist[1], edge = "-->")
} else {
data.frame(from = edgelist[1], to = edgelist[2], edge = edgelist[3])
}
}
i <- 12
toadd <- as.list(do.call(rbind, lapply(allgraphstotest[i, ], strtoaddedges)))
thisg <- do.call(add_edges, c(mutate_caugi(targets, "AG"), toadd))
is_ag <- tryCatch(is_ag(thisg, force_check = TRUE), error = \(e) FALSE)
if(!is_ag) {
next
}
newg <- build(thisg)
newg
plot(newg)
?condition_marginalize
margg <- condition_marginalize(newg, cond_vars = "S")
margg
plot(margg)
is_dag(margg, force_check = TRUE)
j <- 0
cand_graphs <- NULL
for(i in 1:nrow(allgraphstotest)) {
toadd <- as.list(do.call(rbind, lapply(allgraphstotest[i, ], strtoaddedges)))
thisg <- do.call(add_edges, c(mutate_caugi(targets, "AG"), toadd))
is_ag <- tryCatch(is_ag(thisg, force_check = TRUE), error = \(e) FALSE)
if(!is_ag) {
next
}
newg <- build(thisg)
margg <- condition_marginalize(newg, cond_vars = "S")
if(is_dag(margg, force_check = TRUE) && shd(margg, target) == 0) {
cand_graphs[[j + 1]] <- newg
j <- j + 1
}
}
cand_graphs
