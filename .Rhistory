library(readxl)
pord <- read_excel("~/Downloads/Eurocim2026_updated227.xlsx", sheet = 3)
blak <- read_excel("~/Downloads/Eurocim2026_updated227.xlsx", sheet = 2)
res <- merge(pord, blak, by.x = "Porder", by.y = "Presenting author's surname")
sink(file = "stracts.md")
for(i in 1:nrow(res)) {
tr <- res[i,]
cat(paste0(tr$`Presenting author's first name(s)`, " ", tr$Porder, ", ", tr$`Presenting author's affiliation (Department/group, institute, country)`), "\n")
cat(paste0("**Title:** ", tr$`Title of submission (max 250 characters)`), "\n\n",
paste0("**Abstract:** ", tr$`Abstract (max 1250 characters)`), "\n\n")
if(tr$`Full names and affiliations of coauthors` != "") {
cat(tr$`Full names and affiliations of coauthors`)
}
}
sink(NULL)
